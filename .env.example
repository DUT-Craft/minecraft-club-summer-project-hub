# 本地/服务器普通运行：使用本地文件保存数据
DATA_STORAGE=local
LOCAL_DATA_DIR=./data

# 前端请求后端 API 的基础地址
NEXT_PUBLIC_API_BASE=/api

# 管理后台
ADMIN_PASSWORD=change-this-password
ADMIN_SESSION_SECRET=replace-with-a-long-random-secret

# Vercel 试运行推荐：改为 GitHub 私有仓库保存数据
# DATA_STORAGE=github
# GITHUB_TOKEN=github_pat_xxx
# GITHUB_REPO=owner/private-repo-name
# GITHUB_BRANCH=main
# GITHUB_DATA_PATH=data
